# PRiSM Configuration
# Copy this file to .env - ready to use with the htx_example dataset!
# =============================================================================

# =============================================================================
# DATASET/CONFIG SELECTION
# =============================================================================

# Full config mode (loads example_notebooks/config/{name}.yaml)
# The htx_example config is pre-configured for the included heart transplant dataset
PRISM_CONFIG=htx_example

# Alternative: Quick mode - just dataset name, uses notebook defaults
# Uncomment below and comment out PRISM_CONFIG above to use quick mode
# PRISM_DATASET=my_data

# If both are set, PRISM_CONFIG takes precedence

# =============================================================================
# OPTIONAL: Override output/data directories
# =============================================================================
# These are useful for parallel execution or custom directory layouts

# PRISM_MODELS_DIR=
# PRISM_INTERIM_DATA_DIR=
# PRISM_PROCESSED_DATA_DIR=
